# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: read token (needed for private datasets or draft previews)
# SANITY_API_READ_TOKEN=your_read_token

# ── Tracking pixels ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXXX
