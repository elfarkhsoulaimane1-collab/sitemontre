{
  "compilerOptions": {
    "target":         "ES2017",
    "module":         "ESNext",
    "moduleResolution": "Bundler",
    "lib":            ["ES2017", "DOM", "DOM.Iterable"],
    "jsx":            "react-jsx",
    "strict":         true,
    "esModuleInterop": true,
    "skipLibCheck":   true,
    "noEmit":         true,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../src/sanity/**/*.ts"]
}
